{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2017"],
    "allowJs": false,
    "jsx": "react-native",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@devraj-labs/vajra-ui-core": ["./node_modules/@devraj-labs/vajra-ui-core/src/index.ts"],
      "@devraj-labs/vajra-ui-core/*": ["./node_modules/@devraj-labs/vajra-ui-core/src/*"],
      "react-native": ["./examples/app/node_modules/react-native"],
      "react-native/*": ["./examples/app/node_modules/react-native/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "examples"]
}
